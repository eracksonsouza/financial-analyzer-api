# Modo debug: true em dev (mostra stack traces), false em produção
APP_DEBUG=false

# Chave da API do provedor de IA (OpenAI, OpenRouter, Groq, DeepSeek, Together, Ollama, etc.)
AI_API_KEY=sk-...

# Endpoint compatível com OpenAI Chat Completions (opcional — default: OpenAI)
# Exemplos:
#   https://api.openai.com/v1/chat/completions
#   https://openrouter.ai/api/v1/chat/completions
#   https://api.groq.com/openai/v1/chat/completions
#   https://api.deepseek.com/v1/chat/completions
#   http://localhost:11434/v1/chat/completions  (Ollama)
AI_API_URL=https://api.openai.com/v1/chat/completions

# Modelo a ser usado (opcional — default: gpt-4o-mini)
AI_MODEL=gpt-4o-mini

# CORS (separar por vírgula quando houver mais de uma origem)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Banco de dados (PostgreSQL)
#
# Em produção (Railway), ao adicionar um PostgreSQL no projeto, normalmente ele fornece uma variável
# `DATABASE_URL` automaticamente. Exemplo:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial

# (Opcional) Fallback para SQLite apenas para dev/local:
# DB_PATH=/data/financial.db
