{
  "name": "financial-analyzer/backend",
  "description": "Financial Analyzer API",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.3",
    "monolog/monolog": "^3.0",
    "php-di/php-di": "^7.0",
    "slim/psr7": "^1.7",
    "slim/slim": "^4.14"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse"
  },
  "config": {
    "sort-packages": true
  }
}
